<section id='interactive-terminal' class='animate mb-14 w-full' aria-labelledby='terminal-heading'>
  <div class='mb-3 flex flex-wrap items-center gap-3 px-1 font-mono text-xs text-muted-foreground sm:text-sm'>
    <span class='rounded-full border border-dashed px-3 py-1'>// power user?</span>
    <span>跳过滚动，试试交互式 CLI。输入 <code>help</code>、<code>whoami</code> 或 <code>ls</code>。</span>
  </div>

  <div class='terminal-window overflow-hidden rounded-2xl border shadow-lg'>
    <div class='terminal-bar grid grid-cols-[auto_1fr_auto] items-center gap-3 border-b px-4'>
      <div class='flex gap-2' aria-hidden='true'>
        <span class='terminal-light terminal-light-red'></span>
        <span class='terminal-light terminal-light-yellow'></span>
        <span class='terminal-light terminal-light-green'></span>
      </div>
      <p id='terminal-heading' class='truncate text-center font-mono text-xs text-muted-foreground sm:text-sm'>
        sia@siaspace — terminal
      </p>
      <button
        id='terminal-focus'
        type='button'
        class='rounded-md px-2 py-1 font-mono text-xs text-muted-foreground hover:bg-muted hover:text-foreground'
        aria-label='聚焦终端输入框'
      >
        press `
      </button>
    </div>

    <div class='terminal-body'>
      <div
        id='terminal-output'
        class='whitespace-pre-wrap'
        aria-live='polite'
      ></div>

      <form id='terminal-form' class='terminal-input-row flex items-center gap-2'>
        <label for='terminal-input' class='terminal-prompt shrink-0'>sia@siaspace ~ $</label>
        <input
          id='terminal-input'
          type='text'
          class='min-w-0 flex-1 border-0 bg-transparent p-0 text-foreground outline-none placeholder:text-muted-foreground/70'
          placeholder='click or press ` then type help'
          autocomplete='off'
          autocapitalize='off'
          spellcheck='false'
        />
      </form>
    </div>
  </div>
</section>

<script>
  const terminal = document.querySelector<HTMLElement>('#interactive-terminal')
  const focusButton = document.querySelector<HTMLButtonElement>('#terminal-focus')
  const form = document.querySelector<HTMLFormElement>('#terminal-form')
  const input = document.querySelector<HTMLInputElement>('#terminal-input')
  const output = document.querySelector<HTMLElement>('#terminal-output')

  const history: string[] = []
  let historyIndex = 0

  const routes: Record<string, string> = {
    home: '/', blog: '/blog', notes: '/notes', talks: '/talks', projects: '/projects',
    links: '/links', about: '/about', contact: '/contact'
  }

  function print(text = '', tone: 'normal' | 'muted' | 'accent' | 'error' = 'normal') {
    if (!output) return
    const line = document.createElement('div')
    line.textContent = text
    line.dataset.tone = tone
    output.appendChild(line)
    output.scrollTop = output.scrollHeight
  }

  function printWelcome() {
    print('SIA TERM V0.1 · SIASPACE', 'accent')
    print('an interactive shell into this site — try help, whoami, or ls.', 'muted')
    print()
    print("type 'help' to get started · 'whoami' for the short version")
    print()
  }

  function focusTerminal() {
    terminal?.scrollIntoView({ behavior: 'smooth', block: 'center' })
    window.setTimeout(() => input?.focus(), 250)
  }

  function navigate(destination: string) {
    const route = routes[destination]
    if (!route) {
      print(`找不到页面：${destination}`, 'error')
      return
    }
    print(`正在打开 ${destination} ...`, 'muted')
    window.location.href = route
  }

  function runCommand(rawCommand: string) {
    const raw = rawCommand.trim()
    if (!raw) return
    print(`sia@web:~$ ${raw}`, 'muted')
    const [command, ...args] = raw.toLowerCase().split(/\s+/)

    if (command === 'help') {
      print('Available commands', 'accent')
      print('  about / whoami     查看 Sia 的简介')
      print('  ls                 列出网站栏目')
      print('  cd <page>          打开指定栏目')
      print('  blog, notes, talks, projects, links, contact')
      print('  github             打开 GitHub')
      print('  status             查看网站状态')
      print('  theme              切换深浅主题')
      print('  date               显示当前时间')
      print('  clear              清空终端')
      return
    }
    if (command === 'about' || command === 'whoami') {
      print('Sia — Developer · Builder · Lifelong Learner', 'accent')
      print('在这里记录技术、项目与持续发生的思考。')
      return
    }
    if (command === 'ls') {
      print(Object.keys(routes).join('  '))
      return
    }
    if (command === 'pwd') {
      print(window.location.pathname)
      return
    }
    if (command === 'cd') {
      if (!args[0] || args[0] === '~') navigate('home')
      else navigate(args[0].replace(/^\//, ''))
      return
    }
    if (command in routes) {
      navigate(command)
      return
    }
    if (command === 'github') {
      print('正在打开 github.com/wxa1225 ...', 'muted')
      window.open('https://github.com/wxa1225', '_blank', 'noopener,noreferrer')
      return
    }
    if (command === 'status') {
      print('● ONLINE', 'accent')
      print('Host: Vercel  |  Framework: Astro  |  Domain: siaspace.vercel.app')
      return
    }
    if (command === 'theme') {
      document.querySelector<HTMLButtonElement>('#toggleDarkMode')?.click()
      print('主题已切换。', 'accent')
      return
    }
    if (command === 'date') {
      print(new Intl.DateTimeFormat('zh-CN', { dateStyle: 'full', timeStyle: 'medium' }).format(new Date()))
      return
    }
    if (command === 'clear') {
      output?.replaceChildren()
      return
    }
    if (command === 'exit' || command === 'quit') {
      print('终端已留在首页，随时可以继续输入命令。', 'muted')
      input?.blur()
      return
    }
    print(`command not found: ${command}`, 'error')
    print('输入 help 查看可用命令。', 'muted')
  }

  function submitCurrentCommand() {
    if (!input) return
    const command = input.value
    if (command.trim()) {
      history.push(command)
      historyIndex = history.length
    }
    input.value = ''
    runCommand(command)
  }

  printWelcome()
  focusButton?.addEventListener('click', focusTerminal)
  terminal?.addEventListener('click', (event) => {
    if ((event.target as HTMLElement).closest('a, button, input')) return
    input?.focus()
  })
  form?.addEventListener('submit', (event) => {
    event.preventDefault()
    submitCurrentCommand()
  })
  input?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      event.preventDefault()
      submitCurrentCommand()
    } else if (event.key === 'ArrowUp') {
      event.preventDefault()
      historyIndex = Math.max(0, historyIndex - 1)
      input.value = history[historyIndex] ?? ''
    } else if (event.key === 'ArrowDown') {
      event.preventDefault()
      historyIndex = Math.min(history.length, historyIndex + 1)
      input.value = history[historyIndex] ?? ''
    }
  })
  document.addEventListener('keydown', (event) => {
    const target = event.target as HTMLElement | null
    const isTyping = target?.tagName === 'INPUT' || target?.tagName === 'TEXTAREA' || target?.isContentEditable
    if (event.key === '`' && !isTyping) {
      event.preventDefault()
      focusTerminal()
    }
  })
</script>

<style>
  .terminal-window {
    --terminal-accent: 201 92% 32%;
    position: relative;
    isolation: isolate;
    border-color: hsl(var(--foreground) / 0.28);
    background: linear-gradient(180deg, hsl(var(--card) / 0.96), hsl(var(--card) / 0.88));
    color: hsl(var(--foreground));
    font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;
    backdrop-filter: blur(18px) saturate(140%);
    box-shadow:
      0 0 0 1px hsl(var(--foreground) / 0.16),
      0 1px 0 hsl(var(--background) / 0.65) inset,
      0 24px 48px -28px hsl(var(--foreground) / 0.3),
      0 8px 24px -16px hsl(var(--foreground) / 0.2);
  }
  .terminal-window::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(hsl(var(--foreground) / 0.035) 1px, transparent 1px),
      linear-gradient(90deg, hsl(var(--foreground) / 0.035) 1px, transparent 1px);
    background-size: 28px 28px;
    background-position: -1px -1px;
    mask-image: radial-gradient(ellipse 75% 65% at 50% 0%, black 0%, transparent 85%);
  }
  .terminal-window::after {
    content: '';
    position: absolute;
    inset: -1px;
    z-index: -1;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(140deg, hsl(var(--terminal-accent) / 0.22), transparent 30%, transparent 70%, hsl(var(--terminal-accent) / 0.12));
    mix-blend-mode: overlay;
  }
  .terminal-bar {
    position: relative;
    z-index: 1;
    height: 44px;
    background: hsl(var(--background) / 0.55);
    border-color: hsl(var(--border) / 0.8);
    letter-spacing: 0.02em;
    user-select: none;
  }
  .terminal-light {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    border: 1px solid hsl(var(--foreground) / 0.18);
    box-shadow: 0 1px 1px hsl(var(--foreground) / 0.08) inset;
  }
  .terminal-light-red { background: #ff6058; border-color: #ce4640; }
  .terminal-light-yellow { background: #ffbd2e; border-color: #cf9d20; }
  .terminal-light-green { background: #28c93f; border-color: #1e9c30; }
  .terminal-body {
    position: relative;
    z-index: 1;
    height: 420px;
    max-height: 60vh;
    overflow-y: auto;
    padding: 24px 26px 18px;
    font-size: 14px;
    line-height: 1.7;
    scroll-behavior: smooth;
  }
  .terminal-body::-webkit-scrollbar { width: 6px; }
  .terminal-body::-webkit-scrollbar-thumb { background: hsl(var(--muted-foreground) / 0.25); border-radius: 999px; }
  #terminal-output { border-bottom: 1px dashed hsl(var(--border) / 0.75); padding-bottom: 18px; }
  .terminal-input-row { padding-top: 20px; }
  .terminal-prompt { color: hsl(var(--terminal-accent)); font-size: inherit; }
  #terminal-output [data-tone='muted'] { color: hsl(var(--muted-foreground)); }
  #terminal-output [data-tone='accent'] {
    color: hsl(var(--terminal-accent));
    font-weight: 600;
    letter-spacing: 0.055em;
  }
  :global(.dark) #terminal-output [data-tone='accent'] { color: #38bdf8; }
  #terminal-output [data-tone='error'] { color: #f87171; }
  code { border: 1px solid hsl(var(--border)); border-radius: 0.35rem; padding: 0.1rem 0.35rem; color: hsl(var(--foreground)); }
  @media (max-width: 640px) {
    .terminal-body { height: 360px; max-height: 68vh; padding: 20px 18px 14px; font-size: 12px; }
    .terminal-bar { height: 40px; }
    .terminal-input-row { align-items: flex-start; }
    .terminal-prompt { white-space: nowrap; }
  }
</style>
