---
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/CommonPage.astro'

const notes = (await getCollection('notes', ({ data }) => import.meta.env.DEV || !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)
const statusCounts = notes.reduce<Record<string, number>>((counts, note) => {
  counts[note.data.status] = (counts[note.data.status] ?? 0) + 1
  return counts
}, {})
const tagCounts = notes.reduce<Record<string, number>>((counts, note) => {
  for (const tag of note.data.tags) counts[tag] = (counts[tag] ?? 0) + 1
  return counts
}, {})
const popularTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0])).slice(0, 12)
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' }).format(date)
---

<PageLayout title='Notes'>
  <p>
    这里记录源码阅读、机制分析和仍在演化的技术理解。Notes 注重准确、可复现和方便继续更新；完整的个人判断与经验叙事放在 Blog。
  </p>

  <div class='not-prose mt-8 grid gap-8 sm:grid-cols-[minmax(0,3fr)_minmax(10rem,1fr)]'>
    <section aria-label='Notes list'>
      <div class='mb-4 text-sm text-muted-foreground'>共 {notes.length} 篇 · 按发布时间倒序</div>
      <div class='flex flex-col gap-3'>
        {notes.map((note) => (
        <a
          class='group rounded-xl border bg-muted/15 px-5 py-4 no-underline transition-colors hover:bg-muted/35'
          href={`/notes/${note.id}`}
        >
          <div class='mb-2 flex flex-wrap items-start justify-between gap-2'>
            <h2 class='font-medium leading-snug text-foreground transition-colors group-hover:text-primary'>{note.data.title}</h2>
            <span class='shrink-0 rounded-full border bg-background px-2.5 py-1 text-[11px] text-muted-foreground'>
              {note.data.status}
            </span>
          </div>
          <p class='text-sm leading-relaxed text-muted-foreground'>{note.data.description}</p>
          <div class='mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-muted-foreground'>
            <time datetime={note.data.publishDate.toISOString()}>{formatDate(note.data.publishDate)}</time>
            {note.data.tags.slice(0, 4).map((tag) => <span>#{tag}</span>)}
            {note.data.tags.length > 4 && <span>+{note.data.tags.length - 4}</span>}
          </div>
        </a>
        ))}
      </div>
    </section>
    <aside class='space-y-7 sm:sticky sm:top-24 sm:self-start' aria-label='Notes overview'>
      <div>
        <h2 class='mb-3 text-sm font-medium text-foreground'>Status</h2>
        <div class='flex flex-wrap gap-2'>
          {Object.entries(statusCounts).map(([status, count]) => <span class='rounded-full border bg-muted/15 px-2.5 py-1 text-xs text-muted-foreground'>{status} · {count}</span>)}
        </div>
      </div>
      <div>
        <h2 class='mb-3 text-sm font-medium text-foreground'>Tags</h2>
        <div class='flex flex-wrap gap-2'>
          {popularTags.map(([tag, count]) => <span class='rounded-full border bg-muted/15 px-2.5 py-1 text-xs text-muted-foreground'>{tag} · {count}</span>)}
        </div>
      </div>
    </aside>
  </div>
</PageLayout>
