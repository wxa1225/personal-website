---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import { TOC } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/ContentLayout.astro'

export const prerender = true

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => import.meta.env.DEV || !data.draft)
  return notes.map((note) => ({
    params: { id: note.id },
    props: { note }
  }))
}

type Props = {
  note: CollectionEntry<'notes'>
}

const { note } = Astro.props
const { Content, headings } = await render(note)
const { description, publishDate, status, tags, title, updatedDate } = note.data
---

<PageLayout meta={{ description, title }} back='/notes'>
  <Fragment slot='sidebar'>
    {!!headings.length && <TOC {headings} />}
  </Fragment>

  <Fragment slot='header'>
    <h1 class='text-2xl font-medium sm:text-3xl'>{title}</h1>
    <p class='mt-3 text-sm leading-relaxed text-muted-foreground'>{description}</p>
    <div class='mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs text-muted-foreground'>
      <span>研究 · {publishDate.toISOString().slice(0, 10)}</span>
      {updatedDate && <span>更新于 {updatedDate.toISOString().slice(0, 10)}</span>}
      <span>{status}</span>
      {tags.map((tag) => <span>#{tag}</span>)}
    </div>
  </Fragment>

  <Content />

  <div slot='bottom'>
    <Button title='Back to Notes' href='/notes' variant='back' />
  </div>
</PageLayout>
