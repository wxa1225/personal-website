---
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'featured', text: '精选项目' },
  { depth: 2, slug: 'experiments', text: '实验与练习' },
  { depth: 2, slug: 'contact', text: '一起创造' }
]
---

<PageLayout title='项目' {headings}>
  <p>
    这里收录我做过、正在做以及准备继续打磨的项目。相比数量，我更在意每个项目解决了什么问题，以及从中学到了什么。
  </p>
  <Button title='访问我的 GitHub' class='w-fit' href='https://github.com/wxa1225' target='_blank'>
    <Icon class='size-5' name='github' slot='before' />
  </Button>

  <h2 id='featured'>精选项目</h2>
  <ProjectSection
    projects={[
      {
        name: "Sia's Space",
        description: '使用 Astro 构建的个人主页、作品集与数字花园，持续记录项目和思考。',
        links: [{ type: 'github', href: 'https://github.com/wxa1225' }]
      }
    ]}
  />

  <h2 id='experiments'>实验与练习</h2>
  <ProjectSection
    projects={[
      {
        name: 'Learning Notes',
        description: '把学习过程中零散的知识整理成可以查询、复用和分享的内容。',
        links: [{ type: 'site', href: '/blog' }]
      },
      {
        name: 'Next Project',
        description: '下一个值得认真完成的项目将在这里出现。',
        links: [{ type: 'github', href: 'https://github.com/wxa1225' }]
      }
    ]}
  />

  <h2 id='contact'>一起创造</h2>
  <p>如果你对某个项目感兴趣，或者有值得一起探索的想法，欢迎通过 GitHub 与我联系。</p>
</PageLayout>
