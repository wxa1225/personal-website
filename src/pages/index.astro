---
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Terminal from '@/components/terminal/Terminal.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import config from '@/site-config'

const languages = ['Python', 'Go', 'TypeScript', 'SQL']
const development = ['FastAPI', 'FastMCP', 'Gin', 'Redis', 'Docker']
const ai = ['LLM Agent', 'MCP', 'SFT / GRPO', 'Vector Search', 'Knowledge Graph']
const tools = ['Git', 'Vercel', 'Milvus', 'Neo4j', 'OpenTelemetry']
---

<PageLayout meta={{ title: '首页' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <img
        src={config.logo.src}
        alt={config.logo.alt || 'Sia'}
        class='h-28 w-28 rounded-full border object-cover p-1'
        loading='eager'
        fetchpriority='high'
        width='112'
        height='112'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='Beijing, China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com/wxa1225' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      <div class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm'>
        <span class='relative flex items-center justify-center'>
          <span class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'></span>
          <span class='size-2 rounded-full bg-green-400'></span>
        </span>
        <p class='font-medium text-muted-foreground'>Open to ideas and opportunities</p>
      </div>
    </section>

    <div
      id='content'
      class='animate relative z-0 flex w-full min-w-0 max-w-full flex-col gap-y-10 md:w-4/5 lg:w-5/6'
    >
      <div id='interactive-terminal' class='-mt-2'>
        <Terminal />
      </div>
      <Section title='About'>
        <p class='text-muted-foreground'>AI Agents · LLM Training · Backend Systems</p>
        <p class='text-muted-foreground'>
          北京邮电大学计算机类方向研究生，关注 AI Agent 与 LLM 系统工程。
          我在个人项目 SkillClaw Summarizer GRPO 中探索 Agent 轨迹摘要、训练数据构建与 SFT/GRPO；
          也曾在加和科技（GoalfyAI）参与 Agent Runtime、MCP 工具服务和平台后端研发。
          我希望把模型能力做成稳定、可评估、真正可用的系统。
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>

      <Section title='Blog'>
        <a
          class='group rounded-xl border bg-muted/20 px-5 py-4 no-underline transition-colors hover:bg-muted/40'
          href='/blog/autonomy-is-a-budget'
        >
          <div class='mb-1 text-sm text-muted-foreground'>2026-07-23 · Agent Systems</div>
          <div class='font-medium text-foreground transition-colors group-hover:text-primary'>
            Autonomy Is a Budget：Agent 应该把自由度留在哪里？
          </div>
          <p class='mt-2 text-sm leading-relaxed text-muted-foreground'>
            从有状态工具、子 Agent 生命周期和权限边界出发，讨论 Execution Harness 应该如何管理模型行为的后果。
          </p>
        </a>
        <Button title='More blogs' class='w-fit self-end' href='/blog' variant='ahead' />
      </Section>

      <Section title='Curated'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='/notes'
            heading='精选内容 · 01'
            subheading='值得反复阅读的资料、工具或观点，内容待补充'
            imagePath='/src/assets/projects/1.avif'
          />
          <ProjectCard
            href='/notes'
            heading='精选内容 · 02'
            subheading='可以是论文、项目、报告或长期参考资料'
            imagePath='/src/assets/projects/2.avif'
          />
        </div>
        <Button title='More curated' class='w-fit self-end' href='/notes' variant='ahead' />
      </Section>

      <Section title='Experience'>
        <Card
          heading='加和科技（GoalfyAI）'
          subheading='AI Agent 平台研发实习'
          date='实习经历'
        >
          <ul class='ms-4 list-disc text-muted-foreground'>
            <li>参与 Agent Runtime、MCP 工具服务和平台后端相关研发。</li>
            <li>接触工具与提示词资产管理、检索、权限控制、消息队列和可观测性等工程模块。</li>
          </ul>
        </Card>
        <Card
          heading='SkillClaw Summarizer GRPO'
          subheading='Agent 轨迹摘要与强化学习优化'
          date='个人项目'
        />
      </Section>

      <Section title='Selected Works'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://github.com/wxa1225/skillclaw-summarizer-grpo'
            heading='SkillClaw Summarizer GRPO'
            subheading='面向 Agent 轨迹摘要的数据构建、SFT/GRPO 训练、奖励设计与离线评测'
            imagePath='/src/assets/projects/3.avif'
          />
          <ProjectCard
            href='/projects'
            heading='GoalfyAI Agent Platform'
            subheading='参与企业级 Agent Runtime、MCP 工具与平台后端基础设施研发'
            imagePath='/src/assets/projects/4.avif'
          />
        </div>
        <Button title='More projects' class='w-fit self-end' href='/projects' variant='ahead' />
      </Section>

      <Section title='Education'>
        <Card
          heading='北京邮电大学'
          subheading='研究生 · 计算机类方向'
          date='2025 - Present'
        />
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Languages' skills={languages} />
        <SkillLayout title='Development' skills={development} />
        <SkillLayout title='AI & Agent' skills={ai} />
        <SkillLayout title='Tools' skills={tools} />
      </Section>

      <Section title='站点统计'>
        <div class='grid grid-cols-2 gap-3 sm:grid-cols-4'>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>0</div>
            <div class='mt-1 text-xs text-muted-foreground'>文章</div>
          </div>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>0</div>
            <div class='mt-1 text-xs text-muted-foreground'>笔记</div>
          </div>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>0</div>
            <div class='mt-1 text-xs text-muted-foreground'>分享</div>
          </div>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>0</div>
            <div class='mt-1 text-xs text-muted-foreground'>项目</div>
          </div>
        </div>
      </Section>
    </div>
  </main>
</PageLayout>
