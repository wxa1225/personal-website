---
import { Button, Card, Icon, Label } from 'astro-pure/user'
import { PostPreview } from 'astro-pure/components/pages'
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/BaseLayout.astro'
import Terminal from '@/components/terminal/Terminal.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import config from '@/site-config'

const languages = ['Python', 'Go', 'TypeScript', 'SQL']
const development = ['FastAPI', 'FastMCP', 'Gin', 'Redis', 'Docker']
const ai = ['LLM Agent', 'MCP', 'SFT / GRPO', 'Vector Search', 'Knowledge Graph']
const tools = ['Git', 'Vercel', 'Milvus', 'Neo4j', 'OpenTelemetry']

const publishedBlogs = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)
const publishedNotes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)
const recentBlogs = publishedBlogs.slice(0, 5)
const recentNotes = publishedNotes.slice(0, 4)
---

<PageLayout meta={{ title: '首页' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <img
        src={config.logo.src}
        alt={config.logo.alt || 'Sia'}
        class='h-28 w-28 rounded-full border object-cover p-1'
        loading='eager'
        fetchpriority='high'
        width='112'
        height='112'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='Beijing, China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com/wxa1225' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      <div class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm'>
        <span class='relative flex items-center justify-center'>
          <span class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'></span>
          <span class='size-2 rounded-full bg-green-400'></span>
        </span>
        <p class='font-medium text-muted-foreground'>Open to ideas and opportunities</p>
      </div>
    </section>

    <div
      id='content'
      class='animate relative z-0 flex w-full min-w-0 max-w-full flex-col gap-y-10 md:w-4/5 lg:w-5/6'
    >
      <div id='interactive-terminal' class='-mt-2'>
        <Terminal />
      </div>
      <Section title='About'>
        <p class='text-muted-foreground'>AI Agents · LLM Training · Backend Systems</p>
        <p class='text-muted-foreground'>
          北京邮电大学计算机类方向研究生，关注 AI Agent 与 LLM 系统工程。
          我在个人项目 SkillClaw Summarizer GRPO 中探索 Agent 轨迹摘要、训练数据构建与 SFT/GRPO；
          也曾在加和科技（GoalfyAI）参与 Agent Runtime、MCP 工具服务和平台后端研发。
          我希望把模型能力做成稳定、可评估、真正可用的系统。
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>

      <Section title='Blog'>
        <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
          {recentBlogs.map((post) => (
            <li class='flex flex-col gap-x-2 sm:flex-row'>
              <PostPreview post={post} />
            </li>
          ))}
        </ul>
        <Button title='More blogs' class='w-fit self-end' href='/blog' variant='ahead' />
      </Section>

      <Section title='Notes'>
        <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
          {recentNotes.map((note) => (
            <li class='post-preview group/card relative flex flex-col rounded-2xl border bg-background px-5 py-2.5 transition-colors ease-in-out hover:bg-muted'>
              <a class='group/link flex w-full flex-col transition-all hover:text-primary sm:flex-row' href={`/notes/${note.id}`} data-astro-prefetch>
                <span class='min-w-[95px] py-1 text-xs text-muted-foreground'>研究</span>
                <div class='z-10 flex-grow'>
                  <div class='flex justify-between gap-3'>
                    <span>{note.data.title}</span>
                    <span class='my-1 shrink-0 text-muted-foreground transition-transform duration-300 group-hover/link:translate-x-1 group-hover/link:text-primary'>→</span>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <Button title='More notes' class='w-fit self-end' href='/notes' variant='ahead' />
      </Section>

      <Section title='Experience'>
        <Card
          heading='加和科技（GoalfyAI）'
          subheading='AI Agent 平台研发实习'
          date='实习经历'
        >
          <ul class='ms-4 list-disc text-muted-foreground'>
            <li>参与 Agent Runtime、MCP 工具服务和平台后端相关研发。</li>
            <li>接触工具与提示词资产管理、检索、权限控制、消息队列和可观测性等工程模块。</li>
          </ul>
        </Card>
        <Card
          heading='SkillClaw Summarizer GRPO'
          subheading='Agent 轨迹摘要与强化学习优化'
          date='个人项目'
        />
      </Section>

      <Section title='Selected Work'>
        <p class='text-sm leading-relaxed text-muted-foreground'>
          三组围绕 Agent 系统工程展开的研究型写作。每个主题由一篇完整 Blog 提出判断，再用三篇 Notes 拆解实现与边界。
        </p>
        <div class='grid grid-cols-1 gap-3'>
          <a
            href='/blog/autonomy-is-a-budget'
            class='group rounded-2xl border bg-background p-5 no-underline transition-all hover:-translate-y-0.5 hover:border-foreground/20 hover:shadow-sm'
          >
            <div class='flex flex-wrap items-start justify-between gap-3'>
              <div>
                <div class='text-xs font-medium uppercase tracking-wider text-primary'>Essay Series · 01</div>
                <h3 class='mt-1.5 text-lg font-medium text-foreground group-hover:text-primary'>Execution Harness</h3>
              </div>
              <span class='text-sm text-muted-foreground transition-transform group-hover:translate-x-1'>→</span>
            </div>
            <p class='mt-2 text-sm leading-relaxed text-muted-foreground'>
              从自主性预算出发，讨论并行 Tool Call、子 Agent 生命周期、执行授权与 Commit Boundary。
            </p>
            <div class='mt-3 flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
              <span class='rounded-full bg-muted px-2.5 py-1'>1 Blog</span>
              <span class='rounded-full bg-muted px-2.5 py-1'>3 Notes</span>
              <span>Runtime · Concurrency · Authorization</span>
            </div>
          </a>

          <a
            href='/blog/agent-capability-software-supply-chain'
            class='group rounded-2xl border bg-background p-5 no-underline transition-all hover:-translate-y-0.5 hover:border-foreground/20 hover:shadow-sm'
          >
            <div class='flex flex-wrap items-start justify-between gap-3'>
              <div>
                <div class='text-xs font-medium uppercase tracking-wider text-primary'>Essay Series · 02</div>
                <h3 class='mt-1.5 text-lg font-medium text-foreground group-hover:text-primary'>Capability Supply Chain</h3>
              </div>
              <span class='text-sm text-muted-foreground transition-transform group-hover:translate-x-1'>→</span>
            </div>
            <p class='mt-2 text-sm leading-relaxed text-muted-foreground'>
              把 Agent Capability 视为软件依赖，分析不可变快照、权限闭包、评测证据与渐进发布。
            </p>
            <div class='mt-3 flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
              <span class='rounded-full bg-muted px-2.5 py-1'>1 Blog</span>
              <span class='rounded-full bg-muted px-2.5 py-1'>3 Notes</span>
              <span>Manifest · Policy · Evaluation</span>
            </div>
          </a>

          <a
            href='/blog/agent-trajectories-as-provenance-graphs'
            class='group rounded-2xl border bg-background p-5 no-underline transition-all hover:-translate-y-0.5 hover:border-foreground/20 hover:shadow-sm'
          >
            <div class='flex flex-wrap items-start justify-between gap-3'>
              <div>
                <div class='text-xs font-medium uppercase tracking-wider text-primary'>Essay Series · 03</div>
                <h3 class='mt-1.5 text-lg font-medium text-foreground group-hover:text-primary'>Agent Provenance</h3>
              </div>
              <span class='text-sm text-muted-foreground transition-transform group-hover:translate-x-1'>→</span>
            </div>
            <p class='mt-2 text-sm leading-relaxed text-muted-foreground'>
              将 Agent Trajectory 建模为 Provenance Graph，用于因果证据、隐私保留、Replay 与影响分析。
            </p>
            <div class='mt-3 flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
              <span class='rounded-full bg-muted px-2.5 py-1'>1 Blog</span>
              <span class='rounded-full bg-muted px-2.5 py-1'>3 Notes</span>
              <span>Events · Integrity · Replay</span>
            </div>
          </a>
        </div>
        <Button title='Browse all writing' class='w-fit self-end' href='/blog' variant='ahead' />
      </Section>

      <Section title='Education'>
        <Card
          heading='北京邮电大学'
          subheading='研究生 · 计算机类方向'
          date='2025 - Present'
        />
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Languages' skills={languages} />
        <SkillLayout title='Development' skills={development} />
        <SkillLayout title='AI & Agent' skills={ai} />
        <SkillLayout title='Tools' skills={tools} />
      </Section>

      <Section title='站点统计'>
        <div class='grid grid-cols-2 gap-3 sm:grid-cols-4'>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>{publishedBlogs.length}</div>
            <div class='mt-1 text-xs text-muted-foreground'>文章</div>
          </div>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>{publishedNotes.length}</div>
            <div class='mt-1 text-xs text-muted-foreground'>笔记</div>
          </div>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>0</div>
            <div class='mt-1 text-xs text-muted-foreground'>分享</div>
          </div>
          <div class='rounded-xl border bg-muted/30 px-4 py-3 text-center'>
            <div class='text-2xl font-medium tabular-nums'>2</div>
            <div class='mt-1 text-xs text-muted-foreground'>项目</div>
          </div>
        </div>
      </Section>
    </div>
  </main>
</PageLayout>
